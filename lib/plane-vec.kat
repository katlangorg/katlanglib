open Math

public Vector = (x, y)

public X((x, y)) = x
public Y((x, y)) = y

public Neg = Vector(-v.X, -v.Y)

public Scale(v, q) = Vector(q * v.X, q * v.Y)

public Add(v, w) = Vector(v.X + w.X, v.Y + w.Y)

public Subtract(v, w) = Vector(v.X - w.X, v.Y - w.Y)

public DotProd = a.X * b.X + a.Y * b.Y

public Magnitude = DotProd(v, v).Sqrt
