open Math

public Vector = (x, y)

public X((x, y)) = x
public Y((x, y)) = y

public Neg = Vector(-v.X, -v.Y)

public Scale(v, q) = Vector(q * v.X, q * v.Y)

public Add(v, vectors...) = Vector(v.X + vectors.map{X}.sum, v.Y + vectors.map{Y}.sum)

public Subtract(v, vectors...) = Vector(v.X - vectors.map{X}.sum, v.Y - vectors.map{Y}.sum)

public DotProd = a.X * b.X + a.Y * b.Y

public Magnitude = DotProd(v, v).Sqrt
